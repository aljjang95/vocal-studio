# ─────────────────────────────────────────────
# HLB 보컬스튜디오 — 환경변수 템플릿
# 이 파일을 복사해 .env.local로 저장하고 실제 값을 채우세요
# .env.local은 절대 git에 커밋하지 마세요
# ─────────────────────────────────────────────

# Anthropic (서버 전용 — NEXT_PUBLIC_ 접두사 사용 절대 금지)
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
# AI_MODEL=claude-sonnet-4-20250514   # 선택사항: 기본값 사용 시 주석 유지

# Supabase
NEXT_PUBLIC_SUPABASE_URL=<SUPABASE_PROJECT_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# Modal (AI 커버 GPU 서버리스)
MODAL_TRAINING_URL=<MODAL_TRAINING_ENDPOINT_URL>
MODAL_CONVERSION_URL=<MODAL_CONVERSION_ENDPOINT_URL>

# Python FastAPI 백엔드 URL
VOCAL_BACKEND_URL=http://localhost:8001

# 선생님 이메일 (storage-url 접근 권한)
TEACHER_EMAIL=teacher@example.com

# 토스페이먼츠 (결제)
TOSSPAYMENTS_SECRET_KEY=<TOSSPAYMENTS_SECRET_KEY>
